# ----- Shared app ports (host -> container) -----
API_PORT=8080
AGENT_PORT=8000
DB_PORT=5432

# ----- PostgreSQL -----
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=upi_app
DB_SSLMODE=disable

# ----- Agent service -----
# Set this to your real key in local .env before running compose.
OPENAI_API_KEY=replace-with-your-openai-key
